# ClaudeCoach env vars. Copy to .env (which is gitignored) and fill in.
#
# Strava API app credentials. Register an app at
# https://www.strava.com/settings/api to get these.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Bootstrap-only refresh token. Optional. The strava skill writes its own
# rotating tokens to .cache/strava/token.json after the first run, and that
# file becomes the source of truth — STRAVA_REFRESH_TOKEN here is only read
# when the cache is missing. If you don't have one yet, leave this blank and
# run `.claude/skills/strava/strava.py auth-code <CODE>` per SKILL.md.
STRAVA_REFRESH_TOKEN=
